# Copy to .env (repo root) for `docker compose`. Do NOT commit the real .env.
# Compose reads this file both for ${VAR} substitution (the db service) and to
# inject the app's runtime config (env_file).

# ---- Database (the db service is created with these on its FIRST run) ----
DB_NAME=bitbalance
DB_USER=bituser
DB_PASSWORD=change-me-strong
DB_ROOT_PASSWORD=change-me-root-strong
# Note: compose overrides DB_HOST=db and DB_PORT=3306 for the app, so it reaches
# the db service over the compose network — no need to set them here.

# ---- App ----
# REQUIRED in production. Generate: openssl rand -hex 32
SESSION_SECRET=
PORT=3000
NODE_ENV=production
# false for plain LAN HTTP (cookies work over http://<ip>:3000). Set true only if
# the app is reached exclusively over HTTPS (e.g. ngrok and nothing else).
COOKIE_SECURE=false
# Same-origin deploys ignore this (the app serves the SPA). Only matters if the
# app is reached from a DIFFERENT origin — then set it to that external URL.
CLIENT_ORIGIN=http://192.168.1.12:3000
# TRUST_PROXY defaults on (1) — correct behind ngrok / a reverse proxy.

# ---- AI Coach (optional; leave blank to disable) ----
AI_PROVIDER=gemini
GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=
# AI_DAILY_LIMIT=
# AI_COACH_MODEL=
# AI_COACH_DAILY_LIMIT=
# AI_COACH_HISTORY_TURNS=

# ---- Google OAuth (optional; the Google button hides itself when blank) ----
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://<your-domain>/api/auth/google/callback

# ---- ngrok tunnel (optional — only used with `docker compose --profile tunnel`) ----
# NGROK_AUTHTOKEN=
# NGROK_DOMAIN=your-name.ngrok-free.dev
